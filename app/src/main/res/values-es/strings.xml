    <string name="referral_recovery_text_1"> • Un código de referido perdido puede recuperarse por 13 XRP.</string>

    <string name="benefits_for_referrals_and_their_partners">Beneficios para referidos y socios:</string>
    <string name="benefits_for_referrals_and_their_partners_1"> • Los referidos y sus socios activos participan en el sorteo diario de LOTTO.</string>
    <string name="benefits_for_referrals_and_their_partners_2"> • Los usuarios con código de referido obtienen una vida extra en cada juego.</string>
    <string name="benefits_for_referrals_and_their_partners_3"> • Los referidos reciben automáticamente un porcentaje de las ganancias de usuarios activos.</string>

    <string name="restrictions_for_non_referral_users">Restricciones para usuarios sin referido:</string>
    <string name="restrictions_for_non_referral_users_1"> • Los usuarios sin referido no tienen vida extra ni participan en el LOTTO.</string>

    <string name="future_plans">Planes futuros:</string>
    <string name="future_plans_1"> • Los beneficios de referido se ampliarán en el futuro.</string>

    <string name="about_benefits_1"> • No somos una cartera oficial de XRP o Ripple.</string>
    <string name="about_benefits_2"> • Tus claves se almacenan solo en el dispositivo.</string>
    <string name="about_benefits_3"> • Al usar la app confirmas tener 18+ años.</string>
    <string name="about_benefits_4"> • Activar una nueva cartera XRP requiere una reserva única de 10 XRP.</string>
    <string name="about_benefits_5"> • Sé referido por 66 XRP y empieza a ganar de tu red.</string>
    <string name="about_benefits_6"> • ¿Perdiste tu código de referido? Recupéralo por 13 XRP.</string>
    <string name="about_benefits_7"> • Los referidos que apuestan diariamente participan en el sorteo nocturno.</string>
    <string name="about_benefits_8"> • Los usuarios con código de referido obtienen una vida extra.</string>
    <string name="about_benefits_9"> • Más del 90% de todas las apuestas perdidas se redistribuyen diariamente.</string>

    <string name="about_benefits">Sobre los beneficios</string>
    <string name="it_s_important_to_know_1"> • Nuestra app es la encarnación de nuestra visión de futuro — juego y cartera en uno.</string>
    <string name="it_s_important_to_know_2"> • Ya no necesitas transferir dinero, recargar saldo ni registrarte.</string>
    <string name="it_s_important_to_know_3"> • No almacenamos ni enviamos tus claves a ningún lugar.</string>
    <string name="it_s_important_to_know_4"> • No arriesgas perder tus fondos.</string>
    <string name="it_s_important_to_know_5"> • Nadie puede bloquearte ni quitarte tu dinero.</string>
    <string name="it_s_important_to_know_6"> • En nuestra visión futura, una sola frase de recuperación lo reemplaza todo.</string>
    <string name="it_s_important_to_know_7"> • La clave de tu cartera es también la clave de todo.</string>
    <string name="it_s_important_to_know_8"> • Tras restaurar la cartera, puedes jugar de inmediato.</string>
    <string name="it_s_important_to_know_9"> • Usa nuestra cartera sin ninguna restricción.</string>
    <string name="it_s_important_to_know_10"> • Para usuarios activos ofrecemos recompensas, SUPER LOTTO y más.</string>
    <string name="it_s_important_to_know_11"> • Cualquier usuario puede ser referido y ganar 5% + del fondo de premios.</string>
    <string name="it_s_important_to_know_12"> • Otras tarifas: ninguna</string>

    <string name="our_advantages">Nuestras ventajas</string>
    <string name="our_advantages_1"> • Todo el sistema funciona completamente de forma automática.</string>
    <string name="our_advantages_2"> • El sistema considera los intereses del usuario al máximo.</string>
    <string name="our_advantages_3"> • Parte del código del sistema es público.</string>
    <string name="our_advantages_4"> • Todo el código será publicado tras la finalización.</string>
    <string name="our_advantages_5"> • Nos esforzamos por las condiciones más justas para todos.</string>
    <string name="our_advantages_6"> • No rastreamos tu ubicación ni otros datos.</string>
    <string name="our_advantages_7"> • No dividimos a los usuarios en clases.</string>
    <string name="our_advantages_8"> • Todas las acciones del juego están registradas permanentemente en el ledger XRP.</string>
    <string name="our_advantages_9"> • Hacemos el sistema lo más automático, seguro y descentralizado posible.</string>
    <string name="our_advantages_10"> • No tenemos endpoints de servidor — toda comunicación va por blockchain.</string>
    <string name="our_advantages_11"> • Planeamos desarrollar más y ampliar las opciones de juego.</string>

