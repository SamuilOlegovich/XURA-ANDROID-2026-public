    <string name="it_is_important_to_know">Información importante:</string>
    <string name="it_is_important_to_know_1"> • No somos una cartera oficial de XRP o Ripple.</string>
    <string name="it_is_important_to_know_2"> • Tus claves se almacenan solo en tu dispositivo.</string>
    <string name="it_is_important_to_know_3"> • Al usar la app confirmas que tienes 18+ años.</string>
    <string name="it_is_important_to_know_4"> • Activar una nueva cartera XRP requiere una reserva de 10 XRP.</string>

    <string name="about_the_application">Acerca de la aplicación:</string>
    <string name="about_the_application_1"> • Nuestra app encarna el futuro del juego y la cartera.</string>
    <string name="about_the_application_2"> • Olvida las transferencias, recargas y registros.</string>
    <string name="about_the_application_3"> • Tus fondos están completamente seguros.</string>
    <string name="about_the_application_4"> • Nuestra visión: una frase de recuperación lo controla todo.</string>
    <string name="about_the_application_5"> • Tras restaurar la cartera puedes jugar de inmediato.</string>
    <string name="about_the_application_6"> • Usa nuestra cartera sin restricciones.</string>
    <string name="about_the_application_7"> • Los usuarios activos reciben recompensas y Super LOTTO.</string>
    <string name="about_the_application_8"> • Cualquier usuario puede ser referido.</string>

    <string name="advantages">Ventajas:</string>
    <string name="advantages_1"> • El sistema funciona completamente de forma automática.</string>
    <string name="advantages_2"> • Leal y democrático, con máximo interés en el usuario.</string>
    <string name="advantages_3"> • Justo para todos.</string>
    <string name="advantages_4"> • No rastreamos tu ubicación.</string>
    <string name="advantages_5"> • Sistema automatizado y seguro.</string>
    <string name="advantages_6"> • Desarrollo y mejora continuos.</string>
    <string name="advantages_7"> • Todas las operaciones del juego están registradas en el ledger XRP.</string>

    <string name="target">Objetivo:</string>
    <string name="target_1"> • Hacer los juegos accesibles en cualquier lugar y momento.</string>
    <string name="target_2"> • Condiciones iguales y justas para todos los usuarios.</string>
    <string name="target_3"> • Un producto donde cada usuario puede participar en el desarrollo.</string>

    <string name="advice">Consejo:</string>
    <string name="advice_1"> • Nuestro proyecto tiene un buen sistema de seguridad, pero la red no garantiza 100% de disponibilidad. Recomendamos comenzar con el nivel más bajo e ir aumentando gradualmente.</string>

