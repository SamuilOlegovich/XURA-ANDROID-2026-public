<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Действует только при android:debuggable="true" (debug-сборки) —
         позволяет разработчику подключать локальный proxy (mitmproxy/Charles)
         для отладки сетевых запросов. В release игнорируется системой. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
