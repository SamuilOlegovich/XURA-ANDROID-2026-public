<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/guess_the_number_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.GuessTheNumberGame"
    tools:ignore="MissingDefaultResource">

    <!-- Balance + Rules row -->
    <LinearLayout
        android:id="@+id/header_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/guess_the_number_game_text_view_tree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat"
            android:text="@string/your_balance"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/your_balance_xrp_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/xura_gold"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="42.50 XRP" />

        <ImageView
            android:id="@+id/rules_of_the_game_link"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_info"
            android:background="@drawable/bg_btn_info"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/rules_of_the_game"
            app:tint="@color/xura_gold" />

    </LinearLayout>

    <!-- GUESS THE NUMBER title -->
    <TextView
        android:id="@+id/guess_the_number_game_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/guess_the_number"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_row" />

    <!-- Game mode badge -->
    <TextView
        android:id="@+id/tv_game_mode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:textAlignment="center"
        android:gravity="center"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guess_the_number_game_text_view"
        tools:text="○ TRIAL" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/guess_the_number_game_text_view_tow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/and_get_36_times_more"
        android:textAlignment="center"
        android:textColor="@color/xura_text_muted"
        android:textSize="11sp"
        android:gravity="center"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_game_mode" />

    <!-- BET INPUT CONTAINER — contains all 4 input styles, only one visible at a time -->
    <LinearLayout
        android:id="@+id/bet_input_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="4dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/numbers_grid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guess_the_number_game_text_view_tow"
        app:layout_constraintVertical_bias="0.5">

        <!-- Style: CHIPS (default) -->
        <LinearLayout
            android:id="@+id/style_chips_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_bet_field"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:hint="@string/place_your_bet"
                app:boxBackgroundColor="@color/xura_glass_fill"
                app:boxStrokeColor="@color/xura_glass_border"
                app:boxStrokeErrorColor="@color/xura_error"
                app:hintTextColor="@color/xura_text_tertiary"
                app:errorEnabled="true"
                app:errorTextColor="@color/xura_error"
                app:suffixText="XRP"
                app:suffixTextColor="@color/xura_cyan">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/bet_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textAlignment="center"
                    android:textColor="@color/xura_text_primary"
                    android:textColorHint="@color/xura_text_muted"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Style: SLIDER + +/− (combined) — max 36 for number game -->
        <LinearLayout
            android:id="@+id/style_slider_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_bet_plus_minus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:gravity="center"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:text="1.0 XRP" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bet_minus"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="52dp"
                    android:layout_height="40dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text=""
                    android:contentDescription="decrease bet"
                    app:icon="@drawable/ic_pm_minus"
                    app:iconTint="@color/xura_cyan"
                    app:iconSize="20dp"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/xura_cyan"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_bet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0.1"
                    android:valueTo="36.0"
                    android:value="1.0"
                    android:stepSize="0.1"
                    app:thumbColor="@color/xura_cyan"
                    app:trackColorActive="@color/xura_cyan"
                    app:trackColorInactive="#3300D4FF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bet_plus"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="52dp"
                    android:layout_height="40dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text=""
                    android:contentDescription="increase bet"
                    app:icon="@drawable/ic_pm_plus"
                    app:iconTint="@color/xura_cyan"
                    app:iconSize="20dp"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/xura_cyan"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Quick-amount chips (shown in all styles) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_amounts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_01_xrp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/chip_01_xrp"
                android:backgroundTint="@color/chip_bg_quick_bet"
                app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_05_xrp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/chip_05_xrp"
                android:backgroundTint="@color/chip_bg_quick_bet"
                app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_1_xrp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/chip_1_xrp"
                android:backgroundTint="@color/chip_bg_quick_bet"
                app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_5_xrp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/chip_5_xrp"
                android:backgroundTint="@color/chip_bg_quick_bet"
                app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_10_xrp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/chip_10_xrp"
                android:backgroundTint="@color/chip_bg_quick_bet"
                app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_20_xrp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/chip_20_xrp"
                android:backgroundTint="@color/chip_bg_quick_bet"
                app:chipStrokeColor="@color/chip_stroke_quick_bet" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Shared error display for non-chip styles -->
        <TextView
            android:id="@+id/tv_bet_input_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/montserrat"
            android:textColor="@color/xura_error"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Number picker grid 1–36 -->
    <GridLayout
        android:id="@+id/numbers_grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:columnCount="6"
        android:rowCount="6"
        app:layout_constraintBottom_toTopOf="@+id/place_bet_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- PLACE BET — gradient border card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/place_bet_linc"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_card_bet_gradient"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/place_bet_linc"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/place_bet_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/place_bet_linc"
            android:textColor="@color/xura_gold"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:layout_constraintBottom_toTopOf="@+id/place_bet_subtitle"
            app:layout_constraintEnd_toStartOf="@+id/place_bet_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/place_bet_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/btn_sub_place_bet"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/place_bet_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/place_bet_title" />

        <ImageView
            android:id="@+id/place_bet_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_target"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/place_bet_progress"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/xura_gold"
            app:trackColor="@color/xura_glass_fill"
            app:trackThickness="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>