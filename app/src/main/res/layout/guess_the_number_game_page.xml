<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/guess_the_number_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.GuessTheNumberGame"
    tools:ignore="MissingDefaultResource">

    <!-- Rules link — top right -->
    <TextView
        android:id="@+id/rules_of_the_game_link"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/rules_of_the_game"
        android:textAlignment="center"
        android:textColor="@color/xura_text_tertiary"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- XURA Logo -->
    <include
        layout="@layout/logo_xura"
        android:id="@+id/imageViewLogo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="90dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="90dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rules_of_the_game_link" />

    <!-- GUESS THE NUMBER title -->
    <TextView
        android:id="@+id/guess_the_number_game_text_view"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/guess_the_number"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageViewLogo" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/guess_the_number_game_text_view_tow"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/and_get_a_hundred_times_more"
        android:textAlignment="center"
        android:textColor="@color/xura_text_muted"
        android:textSize="11sp"
        android:gravity="center"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guess_the_number_game_text_view" />

    <!-- YOUR BALANCE label -->
    <TextView
        android:id="@+id/guess_the_number_game_text_view_tree"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:text="@string/your_balance"
        android:textAlignment="center"
        android:textColor="@color/xura_text_muted"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guess_the_number_game_text_view_tow" />

    <!-- Balance amount -->
    <TextView
        android:id="@+id/your_balance_xrp_text"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="97,456782  XRP"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guess_the_number_game_text_view_tree" />

    <!-- Bet amount input -->
    <EditText
        android:id="@+id/bet_field"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/fields"
        android:ems="10"
        android:hint="@string/place_your_bet"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textColorHint="@color/xura_text_muted"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/numbers_grid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/your_balance_xrp_text"
        app:layout_constraintVertical_bias="0.5" />

    <!-- Number picker grid 1–36 -->
    <GridLayout
        android:id="@+id/numbers_grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:columnCount="6"
        android:rowCount="6"
        app:layout_constraintBottom_toTopOf="@+id/place_bet_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- PLACE BET button -->
    <TextView
        android:id="@+id/place_bet_linc"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_button_primary"
        android:fontFamily="@font/montserrat"
        android:text="@string/place_bet_linc"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.08"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>