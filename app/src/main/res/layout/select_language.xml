                <TextView
                    android:id="@+id/french_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/select_language_french"
                    android:textColor="@color/xura_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    app:layout_constraintBottom_toTopOf="@+id/french_subtitle"
                    app:layout_constraintEnd_toStartOf="@+id/french_icon"
                    app:layout_constraintStart_toStartOf="parent"
