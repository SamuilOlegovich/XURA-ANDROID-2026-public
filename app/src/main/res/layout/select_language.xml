            <!-- GERMAN -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/settings_german_linc"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
