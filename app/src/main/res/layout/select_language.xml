                <ImageView
                    android:id="@+id/german_icon"
                    android:layout_width="36dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_flag_de"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ARABIC -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/settings_arabic_linc"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card_glass_clickable"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/select_language_arabic">

                <TextView
                    android:id="@+id/arabic_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/select_language_arabic"
                    android:textColor="@color/xura_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    app:layout_constraintBottom_toTopOf="@+id/arabic_subtitle"
                    app:layout_constraintEnd_toStartOf="@+id/arabic_icon"
