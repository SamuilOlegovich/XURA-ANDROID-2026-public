                    app:layout_constraintTop_toBottomOf="@+id/spanish_title" />

                <ImageView
                    android:id="@+id/spanish_icon"
                    android:layout_width="36dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
