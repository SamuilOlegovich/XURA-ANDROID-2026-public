<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/select_language_view_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.SelectLanguage"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/xura_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <!-- XURA Logo -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/logo_xura"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="80dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="80dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- SELECT LANGUAGE title -->
        <TextView
            android:id="@+id/settings_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/select_language_text"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/logo_xura" />

        <!-- ENGLISH button -->
        <!-- ENGLISH — glass card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/settings_english_linc"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_card_glass_clickable"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/select_language_english"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/english_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/select_language_english"
                android:textColor="@color/xura_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/english_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/english_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/english_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/btn_sub_english"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/english_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/english_title" />

            <ImageView
                android:id="@+id/english_icon"
                android:layout_width="36dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_flag_en"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- RUSSIAN — cyan card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/settings_russian_linc"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_action_primary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/select_language_russian"
            app:layout_constraintBottom_toTopOf="@+id/settings_english_linc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/russian_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/select_language_russian"
                android:textColor="@color/xura_cyan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/russian_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/russian_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/russian_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/btn_sub_russian"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/russian_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/russian_title" />

            <ImageView
                android:id="@+id/russian_icon"
                android:layout_width="36dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_flag_ru"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>