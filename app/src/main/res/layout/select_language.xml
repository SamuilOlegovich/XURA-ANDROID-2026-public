                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/select_language_german">

                <TextView
                    android:id="@+id/german_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/select_language_german"
                    android:textColor="@color/xura_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    app:layout_constraintBottom_toTopOf="@+id/german_subtitle"
                    app:layout_constraintEnd_toStartOf="@+id/german_icon"
