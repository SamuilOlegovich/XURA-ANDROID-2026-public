<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_rules"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/slot_rules_title"
                android:textAlignment="center"
                android:textColor="#D020A0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="24dp" />

            <!-- Rules text — filled programmatically in RulesOfTheGameSlot.java -->
            <TextView
                android:id="@+id/tv_rules_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/xura_text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
