<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/xura_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="@color/xura_glass_border_strong" />

        <!-- Header: icon + title/address + amount/time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <ImageView
                android:id="@+id/detail_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="14dp"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/detail_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/xura_text_primary" />

                <TextView
                    android:id="@+id/detail_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/montserrat"
                    android:textSize="11sp"
                    android:textColor="@color/xura_text_tertiary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/detail_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/xura_text_primary" />

                <TextView
                    android:id="@+id/detail_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/montserrat"
                    android:textSize="11sp"
                    android:textColor="@color/xura_text_tertiary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@color/xura_glass_border" />

        <!-- Extra info row (tag / memo label) -->
        <LinearLayout
            android:id="@+id/detail_info_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/detail_info_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textSize="10sp"
                android:textColor="@color/xura_text_muted"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/detail_info_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textSize="12sp"
                android:textColor="@color/xura_text_secondary" />

        </LinearLayout>

        <!-- Destination tag row (shown when DestinationTag is present) -->
        <LinearLayout
            android:id="@+id/detail_dest_tag_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/detail_dest_tag_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textSize="10sp"
                android:textColor="@color/xura_text_muted"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/detail_dest_tag_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textSize="12sp"
                android:textColor="@color/xura_text_secondary" />

        </LinearLayout>

        <!-- Bets breakdown section (BET:R: only) -->
        <LinearLayout
            android:id="@+id/detail_bets_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textSize="10sp"
                android:textColor="@color/xura_text_muted"
                android:layout_marginBottom="10dp"
                android:text="@string/detail_bets_breakdown" />

            <!-- Column headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textSize="9sp"
                    android:textColor="@color/xura_text_muted"
                    android:text="@string/detail_col_bet" />

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textSize="9sp"
                    android:textColor="@color/xura_text_muted"
                    android:gravity="end"
                    android:text="@string/detail_col_amount" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textSize="9sp"
                    android:textColor="@color/xura_text_muted"
                    android:gravity="end"
                    android:text="@string/detail_col_odds" />

            </LinearLayout>

            <!-- Thin divider under headers -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/xura_glass_border"
                android:layout_marginBottom="6dp" />

            <!-- Rows populated programmatically -->
            <LinearLayout
                android:id="@+id/detail_bets_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Total row -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/xura_glass_border"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/xura_text_primary"
                    android:text="@string/detail_total" />

                <TextView
                    android:id="@+id/detail_bets_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/xura_gold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
