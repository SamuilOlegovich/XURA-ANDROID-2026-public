<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/select_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.SelectGame"
    tools:ignore="MissingDefaultResource">

    <!-- Become Referral — top center -->
    <TextView
        android:id="@+id/become_referral_linc"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/become_a_referral"
        android:textAlignment="center"
        android:textColor="@color/xura_text_tertiary"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- XURA Logo -->
    <include
            layout="@layout/logo_xura"
            android:id="@+id/become_referral_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/become_referral_linc"
            />

    <!-- SELECT GAME headline -->
    <TextView
        android:id="@+id/select_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/select_game"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/become_referral_text_view" />

    <!-- Select mode label -->
    <TextView
        android:id="@+id/select_game_select_mode_game_linc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/select_game_mode"
        android:textAlignment="center"
        android:textColor="@color/xura_text_muted"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        app:layout_constraintBottom_toTopOf="@+id/guess_the_color_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- GUESS THE COLOR — primary action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/guess_the_color_linc"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_button_primary"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/name_guess_the_color"
        android:textColor="@color/xura_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintBottom_toTopOf="@+id/double_your_bet_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- GUESS THE NUMBER — secondary action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/double_your_bet_linc"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_button_secondary"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/name_guess_the_number"
        android:textColor="@color/xura_text_secondary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintBottom_toTopOf="@+id/roulette_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ROULETTE — coming soon -->
    <TextView
        android:id="@+id/roulette_linc"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/name_roulette"
        android:textAlignment="center"
        android:textColor="@color/xura_text_tertiary"
        android:textSize="16sp"
        android:gravity="center"
        android:letterSpacing="0.06"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/xura_surface"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:itemRippleColor="@color/xura_glass_fill"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
