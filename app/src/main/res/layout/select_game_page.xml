<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/select_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_surface"
    tools:context=".view.SelectGame"
    tools:ignore="MissingDefaultResource">

    <!-- LOGO -->
    <include
        layout="@layout/logo_xura"
        android:id="@+id/logo_xura"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- SELECT GAME headline -->
    <TextView
        android:id="@+id/select_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/select_game"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo_xura" />

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CARD: GUESS THE COLOR                               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/guess_the_color_linc"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_card_color_game"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/name_guess_the_color"
        app:layout_constraintBottom_toTopOf="@+id/double_your_bet_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/select_text_view"
        app:layout_constraintVertical_chainStyle="spread">

        <TextView
            android:id="@+id/color_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/name_guess_the_color"
            android:textColor="@color/xura_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:layout_constraintBottom_toTopOf="@+id/color_subtitle"
            app:layout_constraintEnd_toStartOf="@+id/icon_color"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/color_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/game_color_subtitle"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/icon_color"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/color_title" />

        <LinearLayout
            android:id="@+id/icon_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:orientation="horizontal"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="22dp"
                android:layout_height="38dp"
                android:background="@drawable/shape_playing_card_red" />

            <View
                android:layout_width="22dp"
                android:layout_height="38dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/shape_playing_card_black" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CARD: GUESS THE NUMBER                              -->
    <!-- ═══════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/double_your_bet_linc"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_card_number_game"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/name_guess_the_number"
        app:layout_constraintBottom_toTopOf="@+id/roulette_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guess_the_color_linc">

        <TextView
            android:id="@+id/number_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/name_guess_the_number"
            android:textColor="@color/xura_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:layout_constraintBottom_toTopOf="@+id/number_subtitle"
            app:layout_constraintEnd_toStartOf="@+id/icon_number"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/number_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/game_number_subtitle"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/icon_number"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/number_title" />

        <FrameLayout
            android:id="@+id/icon_number"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="7"
                android:textColor="#5500D4FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:rotation="-14"
                android:layout_gravity="top|start" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="36"
                android:textColor="#4400D4FF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:rotation="10"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="13"
                android:textColor="#3300D4FF"
                android:textSize="8sp"
                android:rotation="-6"
                android:layout_gravity="center"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="?"
                android:textColor="#00D4FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:rotation="6"
                android:layout_gravity="end|center_vertical" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CARD: ROULETTE                                      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/roulette_linc"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_card_roulette_game"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/name_roulette"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/double_your_bet_linc">

        <TextView
            android:id="@+id/roulette_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/name_roulette"
            android:textColor="@color/xura_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:layout_constraintBottom_toTopOf="@+id/roulette_subtitle"
            app:layout_constraintEnd_toStartOf="@+id/icon_roulette"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/roulette_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/game_roulette_subtitle"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/icon_roulette"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/roulette_title" />

        <ImageView
            android:id="@+id/icon_roulette"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:alpha="0.18"
            android:src="@drawable/ic_game_roulette"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Navigation Bar — floating pill -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav"
        android:clipToOutline="true"
        android:elevation="8dp"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:itemRippleColor="@color/xura_glass_fill"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="unlabeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
