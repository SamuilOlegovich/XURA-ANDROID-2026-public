<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/guess_the_color_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.GuessTheColorGame"
    tools:ignore="MissingDefaultResource">

    <!-- Rules link — top right -->
    <TextView
        android:id="@+id/rules_of_the_game_link"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/rules_of_the_game"
        android:textAlignment="center"
        android:textColor="@color/xura_text_tertiary"
        android:textSize="13sp"
        android:letterSpacing="0.06"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <!-- GUESS THE COLOR title -->
    <TextView
        android:id="@+id/name_game_text_view"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/guess_the_color"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rules_of_the_game_link" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/name_game_text_view_tow"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/and_double_the_bet"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textColor="@color/xura_text_muted"
        android:textSize="11sp"
        android:gravity="center"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_game_text_view" />

    <!-- YOUR BALANCE label -->
    <TextView
        android:id="@+id/your_balance_text_view"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:text="@string/your_balance"
        android:textAlignment="center"
        android:textColor="@color/xura_text_muted"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_game_text_view_tow" />

    <!-- Balance amount -->
    <TextView
        android:id="@+id/your_balance_xrp_text"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="97,456782  XRP"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/your_balance_text_view" />

    <!-- Bet amount input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_bet_field"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:hint="@string/place_your_bet"
        app:boxBackgroundColor="@color/xura_glass_fill"
        app:boxStrokeColor="@color/xura_glass_border"
        app:boxStrokeErrorColor="@color/xura_error"
        app:hintTextColor="@color/xura_text_tertiary"
        app:errorEnabled="true"
        app:errorTextColor="@color/xura_error"
        app:suffixText="XRP"
        app:suffixTextColor="@color/xura_cyan"
        app:layout_constraintBottom_toTopOf="@+id/chip_group_amounts"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/bet_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textColorHint="@color/xura_text_muted"
            android:textSize="20sp"
            android:textStyle="bold" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Quick bet amounts chip group -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_amounts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="10dp"
        app:singleSelection="true"
        app:selectionRequired="false"
        app:layout_constraintBottom_toTopOf="@+id/color_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_1_xrp"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/chip_1_xrp"
            android:textColor="@color/xura_text_primary"
            app:chipBackgroundColor="@color/chip_bg_quick_bet"
            app:chipStrokeColor="@color/chip_stroke_quick_bet"
            app:chipStrokeWidth="1dp"
            app:checkedIconVisible="false" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_5_xrp"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/chip_5_xrp"
            android:textColor="@color/xura_text_primary"
            app:chipBackgroundColor="@color/chip_bg_quick_bet"
            app:chipStrokeColor="@color/chip_stroke_quick_bet"
            app:chipStrokeWidth="1dp"
            app:checkedIconVisible="false" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_10_xrp"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/chip_10_xrp"
            android:textColor="@color/xura_text_primary"
            app:chipBackgroundColor="@color/chip_bg_quick_bet"
            app:chipStrokeColor="@color/chip_stroke_quick_bet"
            app:chipStrokeWidth="1dp"
            app:checkedIconVisible="false" />

    </com.google.android.material.chip.ChipGroup>

    <!-- RED bet button — immersive game action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/color_red"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_game_card_red"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/red"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        app:layout_constraintBottom_toTopOf="@+id/color_black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- BLACK bet button — immersive game action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/color_black"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_game_card_dark"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/black"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_constraintTop_toTopOf="parent"
        tools:layout_constraintVertical_bias="0.95" />

</androidx.constraintlayout.widget.ConstraintLayout>