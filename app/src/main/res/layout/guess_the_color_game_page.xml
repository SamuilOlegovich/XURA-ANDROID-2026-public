<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/guess_the_color_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.GuessTheColorGame"
    tools:ignore="MissingDefaultResource">

    <!-- Rules link — top right -->
    <TextView
        android:id="@+id/rules_of_the_game_link"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/rules_of_the_game"
        android:textAlignment="center"
        android:textColor="@color/xura_text_tertiary"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- XURA Logo -->
    <include
        layout="@layout/logo_xura"
        android:id="@+id/imageViewLogo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="90dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="90dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rules_of_the_game_link" />

    <!-- GUESS THE COLOR title -->
    <TextView
        android:id="@+id/name_game_text_view"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/guess_the_color"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageViewLogo" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/name_game_text_view_tow"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/and_double_the_bet"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textColor="@color/xura_text_muted"
        android:textSize="11sp"
        android:gravity="center"
        android:letterSpacing="0.04"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_game_text_view" />

    <!-- YOUR BALANCE label -->
    <TextView
        android:id="@+id/your_balance_text_view"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="24dp"
        android:text="@string/your_balance"
        android:textAlignment="center"
        android:textColor="@color/xura_text_muted"
        android:textSize="9sp"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_game_text_view_tow" />

    <!-- Balance amount -->
    <TextView
        android:id="@+id/your_balance_xrp_text"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="97,456782  XRP"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/your_balance_text_view" />

    <!-- Bet amount input -->
    <EditText
        android:id="@+id/bet_field"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/fields"
        android:ems="10"
        android:hint="@string/place_your_bet"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textColorHint="@color/xura_text_muted"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/color_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- RED bet button — immersive game action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/color_red"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_game_card_red"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/red"
        android:textColor="@color/xura_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        app:layout_constraintBottom_toTopOf="@+id/color_black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- BLACK bet button — immersive game action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/color_black"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_game_card_dark"
        app:backgroundTint="@null"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/black"
        android:textColor="@color/xura_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_constraintTop_toTopOf="parent"
        tools:layout_constraintVertical_bias="0.95" />

</androidx.constraintlayout.widget.ConstraintLayout>