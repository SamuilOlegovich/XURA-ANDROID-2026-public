<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/xura_black">

        <!-- Settings — top center -->
        <TextView
            android:id="@+id/settings_linc"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/settings_main"
            android:textAlignment="center"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:gravity="center"
            android:letterSpacing="0.08"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- XURA Logo — click opens game selection -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/logo_button_link"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="80dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="80dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/settings_linc" />

        <!-- Lotto ticker -->
        <TextView
            android:id="@+id/lotto_text_go_link"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="24dp"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:text="@string/want_to_win"
            android:textAlignment="center"
            android:textColor="@color/xura_text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/logo_button_link" />

        <!-- "YOUR BALANCE" label -->
        <TextView
            android:id="@+id/your_balance_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="24dp"
            android:text="@string/your_balance"
            android:textAlignment="center"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lotto_text_go_link" />

        <!-- Balance amount — the hero number -->
        <TextView
            android:id="@+id/balance_linc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="24dp"
            android:text="97.456782 XRP"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/your_balance_text" />

        <!-- Info link -->
        <TextView
            android:id="@+id/last_text_view"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/info"
            android:textAlignment="center"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@+id/next_link"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- SEND — primary gradient button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/next_link"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/send"
            android:textColor="@color/xura_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintBottom_toTopOf="@+id/request_link"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- REQUEST — secondary glass button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/request_link"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_secondary"
            app:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/request"
            android:textColor="@color/xura_text_secondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintBottom_toTopOf="@+id/transaction_history_link"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Transaction History link -->
        <TextView
            android:id="@+id/transaction_history_link"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/transaction_history"
            android:textAlignment="center"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="13sp"
            android:letterSpacing="0.06"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:layout_constraintTop_toTopOf="parent"
            tools:layout_constraintVertical_bias="0.95" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>