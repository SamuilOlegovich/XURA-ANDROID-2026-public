<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/become_referral_linc"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.BecomeReferral"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/xura_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- XURA Logo -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/logo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <!-- BECOME REFERRAL title -->
        <TextView
            android:id="@+id/text_referral_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:text="@string/become_referral_and_start_earning"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/logo" />

        <!-- Info link -->
        <TextView
            android:id="@+id/referral_info_linc"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/info"
            android:textAlignment="center"
            android:textColor="@color/xura_text_link"
            android:textSize="13sp"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintBottom_toTopOf="@+id/set_referral_linc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- SET REFERRAL button -->
        <TextView
            android:id="@+id/set_referral_linc"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="@font/montserrat"
            android:text="@string/set_referral"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintBottom_toTopOf="@+id/restore_referral"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- RESTORE REFERRAL button -->
        <TextView
            android:id="@+id/restore_referral"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_secondary"
            android:fontFamily="@font/montserrat"
            android:text="@string/restore_referral"
            android:textAlignment="center"
            android:textColor="@color/xura_text_secondary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintBottom_toTopOf="@+id/become_referral"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- BECOME REFERRAL button -->
        <TextView
            android:id="@+id/become_referral"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_card_glass"
            android:fontFamily="@font/montserrat"
            android:text="@string/become_referral"
            android:textAlignment="center"
            android:textColor="@color/xura_text_secondary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>