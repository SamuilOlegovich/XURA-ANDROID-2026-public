<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/referral"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.Referral"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/xura_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <!-- XURA Logo -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/logo_xura"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="80dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="80dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Referral info text -->
        <TextView
            android:id="@+id/referral_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/referral_text"
            android:textAlignment="center"
            android:textColor="@color/xura_text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/logo_xura" />

        <!-- Referral code input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_referral_code_field"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="48dp"
            android:hint="@string/enter_referral_code"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/referral_text_view">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/referral_code_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="18sp"
                android:fontFamily="@font/montserrat" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- SKIP button -->
        <!-- SKIP — glass card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/referral_skip_linc"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_card_glass_clickable"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/skip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/referral_skip_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/skip"
                android:textColor="@color/xura_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/referral_skip_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/referral_skip_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/referral_skip_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/btn_sub_skip"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/referral_skip_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/referral_skip_title" />

            <ImageView
                android:id="@+id/referral_skip_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_close"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- SET — cyan card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/referral_set_linc"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_action_primary"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/set"
            app:layout_constraintBottom_toTopOf="@+id/referral_skip_linc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/referral_set_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/set"
                android:textColor="@color/xura_cyan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/referral_set_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/referral_set_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/referral_set_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/btn_sub_set"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/referral_set_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/referral_set_title" />

            <ImageView
                android:id="@+id/referral_set_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_check_circle"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>