<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/referral"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.Referral"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/xura_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- XURA Logo -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/imageViewLogo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <!-- Referral info text -->
        <TextView
            android:id="@+id/referral_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/referral_text"
            android:textAlignment="center"
            android:textColor="@color/xura_text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageViewLogo" />

        <!-- Referral code input -->
        <EditText
            android:id="@+id/referral_code_field"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="48dp"
            android:background="@drawable/bg_input_xura"
            android:ems="10"
            android:hint="@string/enter_referral_code"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textColorHint="@color/xura_text_muted"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/referral_text_view" />

        <!-- SKIP link -->
        <TextView
            android:id="@+id/referral_skip_linc"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="80dp"
            android:layout_marginEnd="80dp"
            android:layout_marginBottom="36dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/skip"
            android:textAlignment="center"
            android:textColor="@color/xura_text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- SET button -->
        <TextView
            android:id="@+id/referral_set_linc"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="@font/montserrat"
            android:text="@string/set"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08"
            app:layout_constraintBottom_toTopOf="@+id/referral_skip_linc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>