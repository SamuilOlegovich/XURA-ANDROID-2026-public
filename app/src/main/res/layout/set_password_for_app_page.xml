<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/set_password_for_app_page"
    android:background="@color/xura_black"
    tools:context=".view.SetAnAppPassword"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/xura_black">


        <!-- XURA Logo -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/logo_xura"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="80dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="80dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- SET APP PASSWORD title -->
        <TextView
            android:id="@+id/settings_set_password_app_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/set_password_to_enter_application"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/logo_xura" />

        <!-- Password input 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_settings_set_password_app_field"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="48dp"
            android:hint="@string/enter_password_low_case"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/xura_text_muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/settings_set_password_app_text_view"
            app:layout_constraintBottom_toTopOf="@+id/til_settings_set_password_app_field_tow"
            app:layout_constraintVertical_bias="0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/settings_set_password_app_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="20sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password input 2 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_settings_set_password_app_field_tow"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="48dp"
            android:layout_marginBottom="24dp"
            android:hint="@string/repeat_enter"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/xura_text_muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/til_settings_set_password_app_field"
            app:layout_constraintBottom_toTopOf="@+id/settings_set_password_app_confirm_link"
            app:layout_constraintVertical_bias="0"
            >

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/settings_set_password_app_field_tow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="20sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- SKIP button -->
        <!-- SKIP — glass card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/settings_set_password_app_skip_linc"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_card_glass_clickable"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/skip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/skip_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/skip"
                android:textColor="@color/xura_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/skip_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/skip_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/skip_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/btn_sub_skip"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/skip_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/skip_title" />

            <ImageView
                android:id="@+id/skip_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_close"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- SET PASSWORD — pink card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/settings_set_password_app_confirm_link"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_send"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/set_password"
            app:layout_constraintBottom_toTopOf="@+id/settings_set_password_app_skip_linc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/confirm_password_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/set_password"
                android:textColor="@color/xura_pink"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/confirm_password_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/confirm_password_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/confirm_password_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/btn_sub_set_password"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/confirm_password_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/confirm_password_title" />

            <ImageView
                android:id="@+id/confirm_password_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_lock"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/xura_pink" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>