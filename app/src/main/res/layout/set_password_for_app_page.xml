<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/set_password_for_app_page"
    android:background="@color/xura_black"
    tools:context=".view.SetAnAppPassword"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/xura_black">

        <!-- XURA Logo -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/imageViewLogo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="90dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <!-- SET APP PASSWORD title -->
        <TextView
            android:id="@+id/settings_set_password_app_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:text="@string/set_password_to_enter_application"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageViewLogo" />

        <!-- Password input 1 -->
        <EditText
            android:id="@+id/settings_set_password_app_field"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="48dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="48dp"
            android:background="@drawable/bg_input_xura"
            android:ems="10"
            android:hint="@string/enter_password_low_case"
            android:inputType="numberPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textColorHint="@color/xura_text_muted"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/settings_set_password_app_text_view" />

        <!-- Password input 2 -->
        <EditText
            android:id="@+id/settings_set_password_app_field_tow"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="48dp"
            android:background="@drawable/bg_input_xura"
            android:ems="10"
            android:hint="@string/repeat_enter"
            android:inputType="numberPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textColorHint="@color/xura_text_muted"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/settings_set_password_app_field" />

        <!-- SKIP link -->
        <TextView
            android:id="@+id/settings_set_password_app_skip_linc"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="80dp"
            android:layout_marginEnd="80dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/skip"
            android:textAlignment="center"
            android:textColor="@color/xura_text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:layout_constraintTop_toTopOf="parent"
            tools:layout_constraintVertical_bias="0.95" />

        <!-- SET PASSWORD button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_set_password_app_confirm_link"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/set_password"
            android:textColor="@color/xura_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintBottom_toTopOf="@+id/settings_set_password_app_skip_linc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>