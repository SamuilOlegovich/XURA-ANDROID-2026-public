<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/slot_game_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.SlotGame">

    <ScrollView
        android:id="@+id/slot_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:background="@color/xura_black"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- Balance + Rules row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/your_balance"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/xura_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="42.50 XRP" />

                <!-- Rules info button -->
                <ImageView
                    android:id="@+id/tv_rules_link"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_info"
                    android:background="@drawable/bg_btn_info"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/rules_of_the_game"
                    app:tint="@color/xura_gold" />

            </LinearLayout>

            <!-- SLOT MACHINE title -->
            <TextView
                android:id="@+id/tv_slot_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/name_slot"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.12" />

            <!-- REEL PREVIEW CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/slot_reel_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/xura_card"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/xura_glass_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Reels row -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="160dp">

                        <!-- Three reels -->
                        <LinearLayout
                            android:id="@+id/reel_preview_container"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_reel_preview"
                            android:clipToOutline="true"
                            android:orientation="horizontal">

                            <com.samuilolegovich.view.SlotReelView
                                android:id="@+id/reel_preview_left"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#40D020A0" />

                            <com.samuilolegovich.view.SlotReelView
                                android:id="@+id/reel_preview_center"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#40D020A0" />

                            <com.samuilolegovich.view.SlotReelView
                                android:id="@+id/reel_preview_right"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                        </LinearLayout>

                        <!-- Payline overlay -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_gravity="center_vertical"
                            android:background="#66FF3060"
                            android:importantForAccessibility="no" />

                    </FrameLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- BET INPUT CONTAINER — slider always shown, chips as quick-select -->
            <LinearLayout
                android:id="@+id/bet_input_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <!-- Текущая ставка -->
                <TextView
                    android:id="@+id/tv_bet_plus_minus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:fontFamily="@font/montserrat"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:textColor="@color/xura_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:text="1.0 XRP" />

                <!-- [−]  ══════слайдер══════  [+] -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bet_minus"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="52dp"
                        android:layout_height="40dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:fontFamily="@font/montserrat"
                        android:text="−"
                        android:textColor="#D020A0"
                        android:textSize="20sp"
                        app:strokeColor="#D020A0"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_bet"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0.1"
                        android:valueTo="100.0"
                        android:value="1.0"
                        android:stepSize="0.1"
                        app:thumbColor="#D020A0"
                        app:trackColorActive="#D020A0"
                        app:trackColorInactive="#33D020A0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bet_plus"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="52dp"
                        android:layout_height="40dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:fontFamily="@font/montserrat"
                        android:text="+"
                        android:textColor="#D020A0"
                        android:textSize="20sp"
                        app:strokeColor="#D020A0"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="10dp" />

                </LinearLayout>

                <!-- Quick-amount chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/quick_amounts"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_amounts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="4dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_01"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_01_xrp"
                        android:backgroundTint="@color/chip_bg_slot"
                        app:chipStrokeColor="@color/chip_stroke_slot" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_05"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_05_xrp"
                        android:backgroundTint="@color/chip_bg_slot"
                        app:chipStrokeColor="@color/chip_stroke_slot" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_1"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_1_xrp"
                        android:backgroundTint="@color/chip_bg_slot"
                        app:chipStrokeColor="@color/chip_stroke_slot" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_5"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_5_xrp"
                        android:backgroundTint="@color/chip_bg_slot"
                        app:chipStrokeColor="@color/chip_stroke_slot" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_10"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_10_xrp"
                        android:backgroundTint="@color/chip_bg_slot"
                        app:chipStrokeColor="@color/chip_stroke_slot" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Error display -->
                <TextView
                    android:id="@+id/tv_bet_input_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/xura_error"
                    android:textSize="11sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- SPIN — magenta card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_spin"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_slot"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/slot_spin_button">

                <TextView
                    android:id="@+id/spin_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/slot_spin_button"
                    android:textColor="#D020A0"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    app:layout_constraintBottom_toTopOf="@+id/spin_subtitle"
                    app:layout_constraintEnd_toStartOf="@+id/spin_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed" />

                <TextView
                    android:id="@+id/spin_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/slot_spin_subtitle"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp"
                    android:letterSpacing="0.02"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/spin_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/spin_title" />

                <ImageView
                    android:id="@+id/spin_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_slot_machine"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
