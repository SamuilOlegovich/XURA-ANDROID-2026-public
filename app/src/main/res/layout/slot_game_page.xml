<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    android:fillViewport="true"
    tools:context=".view.SlotGame">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- LOGO -->
        <include
            layout="@layout/logo_xura"
            android:id="@+id/logo_xura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="80dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="80dp" />

        <!-- SLOT MACHINE title -->
        <TextView
            android:id="@+id/tv_slot_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/name_slot"
            android:textAlignment="center"
            android:textColor="#D020A0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <!-- Game mode badge TRIAL / LIVE -->
        <TextView
            android:id="@+id/tv_game_mode_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip_trial"
            android:fontFamily="@font/montserrat"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/xura_black"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Balance label -->
        <TextView
            android:id="@+id/tv_balance_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/your_balance"
            android:textAlignment="center"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.12" />

        <!-- Balance value -->
        <TextView
            android:id="@+id/tv_balance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="@font/montserrat"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- ═══ CHIPS STYLE BET INPUT ═══ -->
        <LinearLayout
            android:id="@+id/style_chips_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_bet_field"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/slot_bet_hint"
                app:boxStrokeColor="#D020A0"
                app:hintTextColor="#D020A0"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:counterEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_bet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:inputType="numberDecimal"
                    android:textColor="@color/xura_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_amounts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:chipSpacingHorizontal="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_01"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="0.1"
                    android:textColor="@color/xura_text_primary"
                    app:chipBackgroundColor="#1AD020A0"
                    app:chipStrokeColor="#D020A0"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_05"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="0.5"
                    android:textColor="@color/xura_text_primary"
                    app:chipBackgroundColor="#1AD020A0"
                    app:chipStrokeColor="#D020A0"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="1"
                    android:textColor="@color/xura_text_primary"
                    app:chipBackgroundColor="#1AD020A0"
                    app:chipStrokeColor="#D020A0"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_5"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="5"
                    android:textColor="@color/xura_text_primary"
                    app:chipBackgroundColor="#1AD020A0"
                    app:chipStrokeColor="#D020A0"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_10"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="10"
                    android:textColor="@color/xura_text_primary"
                    app:chipBackgroundColor="#1AD020A0"
                    app:chipStrokeColor="#D020A0"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- ═══ SLIDER STYLE BET INPUT ═══ -->
        <LinearLayout
            android:id="@+id/style_slider_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_bet_plus_minus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:textAlignment="center"
                android:textColor="#D020A0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:text="1.0 XRP" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bet_minus"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="−"
                    android:textSize="20sp"
                    android:textColor="#D020A0"
                    app:strokeColor="#D020A0"
                    app:cornerRadius="12dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_bet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:valueFrom="1"
                    android:valueTo="1000"
                    android:value="10"
                    android:stepSize="1"
                    app:thumbColor="#D020A0"
                    app:trackColorActive="#D020A0"
                    app:trackColorInactive="#33D020A0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bet_plus"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="#D020A0"
                    app:strokeColor="#D020A0"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_bet_input_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/xura_error"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Referral field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_referral"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="24dp"
            android:hint="@string/enter_referral_code"
            app:boxStrokeColor="#40D020A0"
            app:hintTextColor="@color/xura_text_tertiary"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_referral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:inputType="text"
                android:textColor="@color/xura_text_secondary"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- SPIN button -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_spin"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_card_slot"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/slot_spin_button">

            <TextView
                android:id="@+id/spin_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/slot_spin_button"
                android:textColor="#D020A0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                app:layout_constraintBottom_toTopOf="@+id/spin_subtitle"
                app:layout_constraintEnd_toStartOf="@+id/spin_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/spin_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/slot_spin_subtitle"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.02"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/spin_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/spin_title" />

            <ImageView
                android:id="@+id/spin_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_slot_machine"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Rules link -->
        <TextView
            android:id="@+id/tv_rules_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/rules_of_the_game"
            android:textColor="@color/xura_text_muted"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
