<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/settings_set_password_for_app"
    android:background="@color/xura_black"
    tools:context=".view.SettingsSetPasswordForApp"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/xura_black">


        <!-- SET APP PASSWORD title -->
        <TextView
            android:id="@+id/settings_set_password_app_text_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:text="@string/set_password_to_enter_application"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Password input 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_password_field"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="48dp"
            android:hint="@string/enter_password_low_case"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/xura_text_muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/settings_set_password_app_text_view">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/password_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="20sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password input 2 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_edit_text_passport_tow"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="48dp"
            android:hint="@string/repeat_enter"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/xura_text_muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/til_password_field">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_passport_tow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="20sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- SET PASSWORD button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirm_link"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/set_password"
            android:textColor="@color/xura_text_on_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>