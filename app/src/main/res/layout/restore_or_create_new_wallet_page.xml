<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/restore_or_create_new_wallet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.RestoreOrCreateNewWallet"
    tools:ignore="MissingDefaultResource">

    <!-- XURA Logo — prominent on onboarding -->
    <include
            layout="@layout/logo_xura"
            android:id="@+id/imageViewLogo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="60dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="60dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

    <!-- RESTORE WALLET — secondary action -->
    <TextView
        android:id="@+id/restore_wallet_linc"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_button_secondary"
        android:fontFamily="@font/montserrat"
        android:text="@string/restore_wallet"
        android:textAlignment="center"
        android:textColor="@color/xura_text_secondary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.08"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- CREATE NEW WALLET — primary action -->
    <TextView
        android:id="@+id/create_new_wallet_linc"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_button_primary"
        android:fontFamily="@font/montserrat"
        android:text="@string/create_new_wallet"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.08"
        app:layout_constraintBottom_toTopOf="@+id/restore_wallet_linc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>