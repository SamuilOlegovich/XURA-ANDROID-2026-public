<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/roulette_game_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.RouletteGame">

    <ScrollView
        android:id="@+id/roulette_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- Rules link -->
            <TextView
                android:id="@+id/rules_of_the_game_link"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/montserrat"
                android:text="@string/rules_of_the_game"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp"
                android:gravity="center"
                android:letterSpacing="0.06" />

            <!-- ROULETTE title -->
            <TextView
                android:id="@+id/roulette_game_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/roulette_game"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.12" />

            <!-- Balance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/your_balance"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/your_balance_xrp_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/xura_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="42.50 XRP" />

            </LinearLayout>

            <!-- Casino table card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/xura_card"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/xura_glass_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Selected bet label -->
                    <TextView
                        android:id="@+id/roulette_selected_bet_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/roulette_select_a_bet"
                        android:textAlignment="center"
                        android:textColor="@color/xura_text_tertiary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08" />

                    <!-- Table in HorizontalScrollView -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Number grid: 0 + 1-36 in 3 rows + 2:1 column buttons
                                 Populated programmatically in RouletteGame.java -->
                            <GridLayout
                                android:id="@+id/roulette_numbers_grid"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:columnCount="15"
                                android:rowCount="3" />

                            <!-- Dozens row: 1st 12 | 2nd 12 | 3rd 12
                                 Populated programmatically to align with number grid -->
                            <LinearLayout
                                android:id="@+id/roulette_dozens_row"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />

                            <!-- Outside bets row: 1-18 | EVEN | RED | BLACK | ODD | 19-36
                                 Populated programmatically -->
                            <LinearLayout
                                android:id="@+id/roulette_outside_row"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />

                        </LinearLayout>

                    </HorizontalScrollView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bet input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_bet_field"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="16dp"
                android:hint="@string/place_your_bet"
                app:boxStrokeColor="@color/xura_glass_border"
                app:hintTextColor="@color/xura_text_tertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/bet_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:inputType="numberDecimal"
                    android:textColor="@color/xura_text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Quick amounts label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/quick_amounts"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp" />

            <!-- Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_amounts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1_xrp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/chip_1_xrp"
                    android:backgroundTint="@color/chip_bg_quick_bet"
                    app:chipStrokeColor="@color/chip_stroke_quick_bet" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_5_xrp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/chip_5_xrp"
                    android:backgroundTint="@color/chip_bg_quick_bet"
                    app:chipStrokeColor="@color/chip_stroke_quick_bet" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_10_xrp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/chip_10_xrp"
                    android:backgroundTint="@color/chip_bg_quick_bet"
                    app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            </com.google.android.material.chip.ChipGroup>

            <!-- SPIN button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_spin_roulette"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/roulette_spin"
                android:textAllCaps="false"
                android:textColor="@color/xura_black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:backgroundTint="@color/xura_gold"
                app:cornerRadius="16dp"
                app:rippleColor="#40000000" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
