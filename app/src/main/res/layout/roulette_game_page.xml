<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/roulette_game_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.RouletteGame">

    <ScrollView
        android:id="@+id/roulette_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:background="@color/xura_black"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- Balance + Rules row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/your_balance"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/your_balance_xrp_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/xura_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="42.50 XRP" />

                <!-- Rules info button -->
                <ImageView
                    android:id="@+id/rules_of_the_game_link"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_info"
                    android:background="@drawable/bg_btn_info"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/rules_of_the_game"
                    app:tint="@color/xura_gold" />

            </LinearLayout>

            <!-- ROULETTE title -->
            <TextView
                android:id="@+id/roulette_game_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/roulette_game"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.12" />

            <!-- ═══════════════════════════════════════
                 CASINO TABLE CARD — vertical layout
                 ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roulette_table_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/xura_card"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/xura_glass_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Bets summary row: label + clear button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/roulette_selected_bet_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat"
                            android:text="@string/roulette_select_a_bet"
                            android:textAlignment="center"
                            android:textColor="@color/xura_text_tertiary"
                            android:textSize="11sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/btn_clear_bets"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:fontFamily="@font/montserrat"
                            android:text="@string/roulette_clear_bets"
                            android:textColor="@color/xura_text_tertiary"
                            android:textSize="10sp"
                            android:letterSpacing="0.06"
                            android:background="@drawable/bg_card_white_outline"
                            android:visibility="gone"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Vertical table — populated in RouletteGame.java -->
                    <LinearLayout
                        android:id="@+id/roulette_table_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- BET INPUT CONTAINER — all 4 input styles -->
            <LinearLayout
                android:id="@+id/bet_input_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <!-- Style: CHIPS (default) -->
                <LinearLayout
                    android:id="@+id/style_chips_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_bet_field"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="24dp"
                        android:hint="@string/place_your_bet"
                        app:boxBackgroundColor="@color/xura_glass_fill"
                        app:boxStrokeColor="@color/xura_glass_border"
                        app:boxStrokeErrorColor="@color/xura_error"
                        app:hintTextColor="@color/xura_text_tertiary"
                        app:errorEnabled="true"
                        app:errorTextColor="@color/xura_error"
                        app:suffixText="XRP"
                        app:suffixTextColor="@color/xura_gold">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/bet_field"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat"
                            android:inputType="numberDecimal"
                            android:textColor="@color/xura_text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Style: SLIDER + +/− (combined) -->
                <LinearLayout
                    android:id="@+id/style_slider_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_bet_plus_minus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="24dp"
                        android:fontFamily="@font/montserrat"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:textColor="@color/xura_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:text="1.0 XRP" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="6dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_bet_minus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="52dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text=""
                            android:contentDescription="decrease bet"
                            app:icon="@drawable/ic_pm_minus"
                            app:iconTint="@color/xura_gold"
                            app:iconSize="20dp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            app:strokeColor="@color/xura_gold"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_bet"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0.1"
                            android:valueTo="100.0"
                            android:value="1.0"
                            android:stepSize="0.1"
                            app:thumbColor="@color/xura_gold"
                            app:trackColorActive="@color/xura_gold"
                            app:trackColorInactive="#33FFB000" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_bet_plus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="52dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text=""
                            android:contentDescription="increase bet"
                            app:icon="@drawable/ic_pm_plus"
                            app:iconTint="@color/xura_gold"
                            app:iconSize="20dp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            app:strokeColor="@color/xura_gold"
                            app:strokeWidth="1.5dp"
                            app:cornerRadius="10dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Quick-amount chips (shown in all styles) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/quick_amounts"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_amounts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="4dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_01_xrp"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_01_xrp"
                        android:backgroundTint="@color/chip_bg_roulette"
                        app:chipStrokeColor="@color/chip_stroke_roulette" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_05_xrp"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_05_xrp"
                        android:backgroundTint="@color/chip_bg_roulette"
                        app:chipStrokeColor="@color/chip_stroke_roulette" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_1_xrp"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_1_xrp"
                        android:backgroundTint="@color/chip_bg_roulette"
                        app:chipStrokeColor="@color/chip_stroke_roulette" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_5_xrp"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_5_xrp"
                        android:backgroundTint="@color/chip_bg_roulette"
                        app:chipStrokeColor="@color/chip_stroke_roulette" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_10_xrp"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_10_xrp"
                        android:backgroundTint="@color/chip_bg_roulette"
                        app:chipStrokeColor="@color/chip_stroke_roulette" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_20_xrp"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/chip_20_xrp"
                        android:backgroundTint="@color/chip_bg_roulette"
                        app:chipStrokeColor="@color/chip_stroke_roulette" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Shared error display for non-chip styles -->
                <TextView
                    android:id="@+id/tv_bet_input_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="24dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/xura_error"
                    android:textSize="11sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- SPIN — gold card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_spin_roulette"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_history"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/roulette_spin">

                <TextView
                    android:id="@+id/spin_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/roulette_spin"
                    android:textColor="@color/xura_gold"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    app:layout_constraintBottom_toTopOf="@+id/spin_subtitle"
                    app:layout_constraintEnd_toStartOf="@+id/spin_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed" />

                <TextView
                    android:id="@+id/spin_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/btn_sub_spin"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp"
                    android:letterSpacing="0.02"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/spin_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/spin_title" />

                <ImageView
                    android:id="@+id/spin_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_spin"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/xura_gold" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/spin_progress"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="16dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorColor="@color/xura_gold"
                    app:trackColor="@color/xura_glass_fill"
                    app:trackThickness="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
