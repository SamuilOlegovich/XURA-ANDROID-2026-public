<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/roulette_game_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.RouletteGame">

    <ScrollView
        android:id="@+id/roulette_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- Rules + Balance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/rules_of_the_game_link"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/rules_of_the_game"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:letterSpacing="0.06" />

                <android.widget.Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/your_balance"
                    android:textColor="@color/xura_text_tertiary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/your_balance_xrp_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/montserrat"
                    android:textColor="@color/xura_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="42.50 XRP" />

            </LinearLayout>

            <!-- ROULETTE title -->
            <TextView
                android:id="@+id/roulette_game_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/roulette_game"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.12" />

            <!-- ═══════════════════════════════════════
                 WHEEL CARD — hidden until SPIN pressed
                 ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roulette_wheel_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/xura_card"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/xura_glass_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="16dp"
                    android:paddingBottom="12dp">

                    <com.samuilolegovich.view.RouletteWheelView
                        android:id="@+id/roulette_wheel_view"
                        android:layout_width="220dp"
                        android:layout_height="220dp" />

                    <!-- Result block — GONE until spin completes -->
                    <LinearLayout
                        android:id="@+id/roulette_result_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="12dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/roulette_result_number"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:fontFamily="@font/montserrat"
                            android:gravity="center"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/xura_text_primary"
                            tools:text="7" />

                        <TextView
                            android:id="@+id/roulette_result_message"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/montserrat"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            tools:text="WON  +42.0 XRP"
                            tools:textColor="@color/xura_gold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════
                 CASINO TABLE CARD — vertical layout
                 ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roulette_table_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/xura_card"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/xura_glass_border"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Selected bet label -->
                    <TextView
                        android:id="@+id/roulette_selected_bet_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/roulette_select_a_bet"
                        android:textAlignment="center"
                        android:textColor="@color/xura_text_tertiary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08" />

                    <!-- Vertical table — populated in RouletteGame.java -->
                    <LinearLayout
                        android:id="@+id/roulette_table_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- BET INPUT -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_bet_field"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="14dp"
                android:hint="@string/place_your_bet"
                app:boxStrokeColor="@color/xura_glass_border"
                app:hintTextColor="@color/xura_text_tertiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/bet_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:inputType="numberDecimal"
                    android:textColor="@color/xura_text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Quick amounts -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/quick_amounts"
                android:textColor="@color/xura_text_tertiary"
                android:textSize="11sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_amounts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1_xrp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/chip_1_xrp"
                    android:backgroundTint="@color/chip_bg_quick_bet"
                    app:chipStrokeColor="@color/chip_stroke_quick_bet" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_5_xrp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/chip_5_xrp"
                    android:backgroundTint="@color/chip_bg_quick_bet"
                    app:chipStrokeColor="@color/chip_stroke_quick_bet" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_10_xrp"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/chip_10_xrp"
                    android:backgroundTint="@color/chip_bg_quick_bet"
                    app:chipStrokeColor="@color/chip_stroke_quick_bet" />

            </com.google.android.material.chip.ChipGroup>

            <!-- SPIN button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_spin_roulette"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/montserrat"
                android:text="@string/roulette_spin"
                android:textAllCaps="false"
                android:textColor="@color/xura_black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:backgroundTint="@color/xura_gold"
                app:cornerRadius="16dp"
                app:rippleColor="#40000000" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
