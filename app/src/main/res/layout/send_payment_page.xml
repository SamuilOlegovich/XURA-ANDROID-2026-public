<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/send_payment_page"
    android:background="@color/xura_black"
    tools:context=".view.SendPayment"
    tools:ignore="MissingDefaultResource">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LayoutSetAnAppPassword"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <!-- SEND PAYMENT title -->
        <TextView
            android:id="@+id/send_payment_page_text_view"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:text="@string/send_payment"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="@font/montserrat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- YOUR BALANCE label -->
        <TextView
            android:id="@+id/send_payment_page_text_view_tow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="24dp"
            android:text="@string/your_balance"
            android:textAlignment="center"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/send_payment_page_text_view" />

        <!-- Balance amount -->
        <TextView
            android:id="@+id/balance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="24dp"
            android:text="97.456782  XRP"
            android:textAlignment="center"
            android:textColor="@color/xura_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/send_payment_page_text_view_tow" />

        <!-- To address input with QR scan icon -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/scan_linc"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:hint="@string/to"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_qr_scan"
            app:endIconTint="@color/xura_cyan"
            app:endIconContentDescription="@string/scan_qr_code"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/balance">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/from_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Amount input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_amount_field"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:hint="@string/amount"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:suffixText="XRP"
            app:suffixTextColor="@color/xura_cyan"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/scan_linc">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/amount_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="20sp"
                android:textStyle="bold" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Destination tag input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_tag_field"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="48dp"
            android:hint="@string/destination_tag"
            app:boxBackgroundColor="@color/xura_glass_fill"
            app:boxStrokeColor="@color/xura_glass_border"
            app:boxStrokeErrorColor="@color/xura_error"
            app:hintTextColor="@color/xura_text_tertiary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/til_amount_field">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tag_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textAlignment="center"
                android:textColor="@color/xura_text_primary"
                android:textColorHint="@color/xura_text_muted"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- SEND button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/send_linc"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/send"
            android:textColor="@color/xura_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:layout_constraintTop_toTopOf="parent"
            tools:layout_constraintVertical_bias="0.9" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>