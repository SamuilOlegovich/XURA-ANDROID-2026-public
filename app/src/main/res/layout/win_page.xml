<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/win_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.Win"
    tools:ignore="MissingDefaultResource">


    <!-- XURA Logo -->
    <include
        layout="@layout/logo_xura"
        android:id="@+id/logo_xura"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- YOU WON! — the hero headline -->
    <TextView
        android:id="@+id/win_page_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/bet_won"
        android:textAlignment="center"
        android:textColor="@color/xura_gold"
        android:textSize="60sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo_xura" />

    <!-- Win amount — scrolling marquee -->
    <TextView
        android:id="@+id/win_page_text_view_tow"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/montserrat"
        android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/win_page_text_view" />

    <!-- CONGRATULATIONS — vertically centered between amount and buttons -->
    <TextView
        android:id="@+id/win_page_text_view_tree"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/congratulations"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toBottomOf="@+id/win_page_text_view_tow"
        app:layout_constraintBottom_toTopOf="@+id/btn_play_again"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <!-- PLAY AGAIN — primary gradient button -->
    <!-- PLAY AGAIN — cyan card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_play_again"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card_action_primary"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/play_again"
        app:layout_constraintBottom_toTopOf="@+id/btn_back_to_games"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/play_again_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/play_again"
            android:textColor="@color/xura_cyan"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:layout_constraintBottom_toTopOf="@+id/play_again_subtitle"
            app:layout_constraintEnd_toStartOf="@+id/play_again_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/play_again_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/btn_sub_play_again"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/play_again_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/play_again_title" />

        <ImageView
            android:id="@+id/play_again_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_gamepad"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/xura_cyan" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BACK TO GAMES — glass card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_back_to_games"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_card_glass_clickable"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/back_to_games"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/back_to_games_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/back_to_games"
            android:textColor="@color/xura_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:layout_constraintBottom_toTopOf="@+id/back_to_games_subtitle"
            app:layout_constraintEnd_toStartOf="@+id/back_to_games_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/back_to_games_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/btn_sub_back_to_games"
            android:textColor="@color/xura_text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/back_to_games_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/back_to_games_title" />

        <ImageView
            android:id="@+id/back_to_games_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_scattered_games"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
