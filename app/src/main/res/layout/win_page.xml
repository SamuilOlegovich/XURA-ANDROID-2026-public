<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/win_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xura_black"
    tools:context=".view.Win"
    tools:ignore="MissingDefaultResource">


    <!-- XURA Logo -->
    <include
        layout="@layout/logo_xura"
        android:id="@+id/logo_xura"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- YOU WON! — the hero headline -->
    <TextView
        android:id="@+id/win_page_text_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/bet_won"
        android:textAlignment="center"
        android:textColor="@color/xura_text_primary"
        android:textSize="60sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo_xura" />

    <!-- Win amount — scrolling marquee -->
    <TextView
        android:id="@+id/win_page_text_view_tow"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="16dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/montserrat"
        android:marqueeRepeatLimit="marquee_forever"
        android:scrollHorizontally="true"
        android:singleLine="true"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/win_page_text_view" />

    <!-- CONGRATULATIONS — vertically centered between amount and buttons -->
    <TextView
        android:id="@+id/win_page_text_view_tree"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/montserrat"
        android:text="@string/congratulations"
        android:textAlignment="center"
        android:textColor="@color/xura_cyan"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toBottomOf="@+id/win_page_text_view_tow"
        app:layout_constraintBottom_toTopOf="@+id/btn_play_again"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.5" />

    <!-- PLAY AGAIN — primary gradient button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_play_again"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_button_primary"
        android:fontFamily="@font/montserrat"
        android:text="@string/play_again"
        android:textAllCaps="false"
        android:textColor="@color/xura_text_on_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:backgroundTint="@android:color/transparent"
        app:cornerRadius="100dp"
        app:rippleColor="#40FFFFFF"
        app:layout_constraintBottom_toTopOf="@+id/btn_back_to_games"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- BACK TO GAMES — secondary glass button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_to_games"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_button_secondary"
        android:fontFamily="@font/montserrat"
        android:text="@string/back_to_games"
        android:textAllCaps="false"
        android:textColor="@color/xura_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        app:backgroundTint="@android:color/transparent"
        app:cornerRadius="100dp"
        app:rippleColor="#40FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
