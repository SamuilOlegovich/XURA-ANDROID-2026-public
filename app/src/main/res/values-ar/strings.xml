    <string name="advantages">المزايا:</string>
    <string name="advantages_1"> • النظام يعمل بشكل تلقائي كامل.</string>
    <string name="advantages_2"> • نظام مخلص وديمقراطي يراعي مصالح المستخدم.</string>
    <string name="advantages_3"> • عادل للجميع.</string>
    <string name="advantages_4"> • لا نتتبع موقعك.</string>
    <string name="advantages_5"> • نظام آلي وآمن.</string>
    <string name="advantages_6"> • تطوير وتحسين مستمران.</string>
    <string name="advantages_7"> • جميع عمليات اللعبة مسجّلة بشكل دائم في سجل XRP.</string>

    <string name="target">الهدف:</string>
    <string name="target_1"> • جعل الألعاب متاحة في أي مكان وأي وقت.</string>
    <string name="target_2"> • شروط متساوية وعادلة لجميع المستخدمين.</string>
